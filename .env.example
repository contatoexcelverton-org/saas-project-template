# ============================================================
# AMBIENTE LOCAL — copie para .env e preencha com valores reais
#
# PRODUÇÃO: cada variável marcada com "# KV: ..." deve estar na
#           App Setting como referência ao Key Vault:
#           @Microsoft.KeyVault(SecretUri=https://kv-{projeto}.vault.azure.net/secrets/{nome}/)
#
# REGRA: NUNCA use os.environ.get("VAR", "valor_real_aqui")
#        Se o valor não estiver disponível, use get_secret_required() e deixe falhar cedo.
# ============================================================

# ─── Azure Identity ────────────────────────────────────────
# (Managed Identity em prod — credenciais locais apenas para dev)
AZURE_TENANT_ID=                        # Não vai para o KV (é configuração, não secret)
AZURE_CLIENT_ID=                        # Não vai para o KV
AZURE_CLIENT_SECRET=                    # KV: azure-client-secret (se não usar MI)

# Key Vault — este sim fica diretamente na App Setting (não pode referenciar o próprio KV)
AZURE_KEYVAULT_URL=https://kv-PROJETO.vault.azure.net/

# ─── PostgreSQL ────────────────────────────────────────────
POSTGRES_HOST=                          # KV: postgres-host
POSTGRES_PORT=5432                      # KV: postgres-port
POSTGRES_DB=                            # KV: postgres-db
POSTGRES_USER=                          # KV: postgres-user
POSTGRES_PASSWORD=                      # KV: postgres-password
POSTGRES_SSLMODE=require                # KV: postgres-sslmode

# ─── Azure OpenAI ──────────────────────────────────────────
AZURE_OPENAI_ENDPOINT=                  # KV: azure-openai-endpoint
AZURE_OPENAI_KEY=                       # KV: azure-openai-key
# IMPORTANTE: deixe em branco — o deployment varia por recurso Azure.
# Veja no portal: Azure OpenAI → Deployments.
# O código usa fallback chain: ["gpt-4.1-mini", "gpt-4o-mini"] se vazio.
AZURE_OPENAI_DEPLOYMENT=                # KV: azure-openai-deployment
AZURE_OPENAI_API_VERSION=2024-08-01-preview

# ─── Azure AI Search ───────────────────────────────────────
AZURE_SEARCH_ENDPOINT=                  # KV: azure-search-endpoint
AZURE_SEARCH_KEY=                       # KV: azure-search-key
AZURE_SEARCH_INDEX=                     # KV: azure-search-index

# ─── Azure Blob Storage ────────────────────────────────────
AZURE_STORAGE_ACCOUNT=                  # KV: azure-storage-account
AZURE_STORAGE_CONTAINER=                # KV: azure-storage-container

# ─── Azure Communication Services ─────────────────────────
AZURE_COMM_CONNECTION_STRING=           # KV: azure-comm-connection-string
AZURE_COMM_SENDER_EMAIL=                # KV: azure-comm-sender-email

# ─── Azure Speech ──────────────────────────────────────────
AZURE_SPEECH_KEY=                       # KV: azure-speech-key
AZURE_SPEECH_REGION=                    # Não sensível — pode ficar na App Setting direta

# ─── Application Insights ──────────────────────────────────
APPLICATIONINSIGHTS_CONNECTION_STRING=  # KV: appinsights-connection-string

# ─── Auth (JWT) ────────────────────────────────────────────
JWT_SECRET=                             # KV: jwt-secret (HS256) OU use private/public key abaixo
JWT_PRIVATE_KEY_PATH=./certs/private.pem  # Para RS256 — não commitar o arquivo .pem
JWT_PUBLIC_KEY_PATH=./certs/public.pem
JWT_ALGORITHM=RS256
JWT_ACCESS_EXPIRE_MINUTES=60
JWT_REFRESH_EXPIRE_DAYS=7

# ─── Stripe ────────────────────────────────────────────────
STRIPE_SECRET_KEY=                      # KV: stripe-secret-key
STRIPE_PUBLISHABLE_KEY=                 # KV: stripe-publishable-key (frontend)
STRIPE_WEBHOOK_SECRET=                  # KV: stripe-webhook-secret
STRIPE_PRICE_ID_MONTHLY=                # KV: stripe-price-id-monthly
STRIPE_PRICE_ID_ANNUAL=                 # KV: stripe-price-id-annual

# ─── Mercado Pago ──────────────────────────────────────────
MERCADOPAGO_ACCESS_TOKEN=               # KV: mercadopago-access-token
MERCADOPAGO_WEBHOOK_SECRET=             # KV: mercadopago-webhook-secret

# ─── Telegram Bot ──────────────────────────────────────────
TELEGRAM_BOT_TOKEN=                     # KV: telegram-bot-token
TELEGRAM_WEBHOOK_URL=                   # Não sensível

# ─── Google OAuth ──────────────────────────────────────────
GOOGLE_CLIENT_ID=                       # KV: google-client-id
GOOGLE_CLIENT_SECRET=                   # KV: google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google/callback

# ─── Google APIs (Analytics, Search Console) ───────────────
GOOGLE_ANALYTICS_PROPERTY_ID=           # Não sensível
# ATENÇÃO: o path para service account JSON NUNCA deve apontar para um arquivo commitado
# Use um path absoluto fora do repo, ou armazene o JSON no Key Vault como string
GOOGLE_SERVICE_ACCOUNT_JSON_PATH=       # Ex: /etc/secrets/google_sa.json
GA4_MEASUREMENT_ID=                     # Não sensível — pode ir no frontend diretamente

# ─── Power BI Embedded (se o projeto usar) ─────────────────
POWERBI_TENANT_ID=                      # Não sensível
POWERBI_CLIENT_ID=                      # KV: powerbi-client-id
POWERBI_CLIENT_SECRET=                  # KV: powerbi-client-secret
POWERBI_WORKSPACE_ID=                   # Não sensível

# ─── Cloudflare ────────────────────────────────────────────
CLOUDFLARE_ZONE_ID=                     # KV: cloudflare-zone-id
CLOUDFLARE_API_KEY=                     # KV: cloudflare-api-key

# ─── Recursos Azure (identificadores — não sensíveis) ──────
FUNCTION_APP_NAME=
RESOURCE_GROUP=
LOCATION=brazilsouth
KV_NAME=kv-PROJETO
SITE_URL=https://meu-projeto.com.br

# ─── Ambiente ──────────────────────────────────────────────
ENVIRONMENT=development
PROJECT_NAME=
LOG_LEVEL=DEBUG
