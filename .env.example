# ============================================================
# AMBIENTE LOCAL — copie para .env e preencha com valores reais
# EM PRODUÇÃO: todas estas variáveis são referências ao Key Vault
#              nas App Settings do Azure Functions
# ============================================================

# Azure Identity (Managed Identity em prod — isso é só para dev local)
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=

# Key Vault (endpoint — este sim pode ficara na app setting diretamente)
AZURE_KEYVAULT_URL=https://kv-PROJETO.vault.azure.net/

# PostgreSQL
POSTGRES_HOST=
POSTGRES_PORT=5432
POSTGRES_DB=
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_SSLMODE=require

# Azure OpenAI
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_KEY=
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_API_VERSION=2024-08-01-preview

# Azure AI Search
AZURE_SEARCH_ENDPOINT=
AZURE_SEARCH_KEY=
AZURE_SEARCH_INDEX=

# Azure Blob Storage
AZURE_STORAGE_ACCOUNT=
AZURE_STORAGE_CONTAINER=

# Azure Communication Services
AZURE_COMM_CONNECTION_STRING=
AZURE_COMM_SENDER_EMAIL=

# Azure Speech
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=

# Application Insights
APPLICATIONINSIGHTS_CONNECTION_STRING=

# Auth (JWT)
JWT_PRIVATE_KEY_PATH=./certs/private.pem
JWT_PUBLIC_KEY_PATH=./certs/public.pem
JWT_ALGORITHM=RS256
JWT_ACCESS_EXPIRE_MINUTES=60
JWT_REFRESH_EXPIRE_DAYS=7

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_MONTHLY=
STRIPE_PRICE_ID_ANNUAL=

# Mercado Pago
MP_ACCESS_TOKEN=
MP_WEBHOOK_SECRET=

# Telegram Bot
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_URL=

# Google APIs
GOOGLE_ANALYTICS_PROPERTY_ID=
GOOGLE_SEARCH_CONSOLE_SITE_URL=
GOOGLE_SERVICE_ACCOUNT_JSON_PATH=

# Ambiente
ENVIRONMENT=development
PROJECT_NAME=
LOG_LEVEL=DEBUG
